# Backend Server Configurations
PORT=5000
MONGO_URI=mongodb://localhost:27017/hostel
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Attendance & Geofencing defaults (Backend)
CHECKIN_TIME=20:00
CUTOFF_TIME=22:00
GEOFENCE_RADIUS_METERS=200
HOSTEL_LAT=23.2815
HOSTEL_LNG=77.4562

# Mailer Configurations
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SENDER_NAME=SISTec Hostel Management
SENDER_EMAIL=no-reply@sistechostel.in

# Frontend Configurations (Vite requires VITE_ prefix to expose them to client)
VITE_API_URL=http://localhost:5000/api
VITE_HOSTEL_LAT=23.2815
VITE_HOSTEL_LNG=77.4562
VITE_GEOFENCE_RADIUS_METERS=200
